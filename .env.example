# Backend
POSTGRES_DSN=postgresql+psycopg://app:app@db:5432/personal_me
JWT_SECRET_KEY=change-me-to-random-long-secret
ALLOW_REGISTRATION=false
EXPOSE_RESET_TOKEN=false
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
CORS_ORIGINS=http://localhost
AUTH_RATE_LIMIT_PER_MINUTE=30
OIDC_ISSUER=http://localhost/api/v1/oidc
OIDC_FRONTEND_BASE_URL=http://localhost
OIDC_AUTO_APPROVE=true

# Email (password reset). Leave SMTP_HOST empty to disable.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true
FEEDBACK_TO_EMAIL=
FEEDBACK_RATE_LIMIT_PER_MINUTE=5

# Initial admin (only used on first seed)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me
INITIAL_ADMIN_EMAIL=

# Site content (about / SEO / terminal about)
# Основная настройка — в админке /admin/seo (seed ниже только при первом запуске)
SITE_OWNER_NAME=Your Name
SITE_TAGLINE=Интерактивный командный центр: портфолио, интеграции и сервисы.
SITE_BIO=Backend-разработчик. Terminal hub с JWT, OIDC и интеграциями.
SITE_EXPERIENCE=2022–н.в. — Backend / Full-stack разработчик\n2020–2022 — Junior Python developer
SITE_SKILLS=Python, FastAPI, PostgreSQL, Nuxt, Docker, OIDC
SITE_GITHUB_URL=
SITE_TELEGRAM=
SITE_RESUME_URL=
SITE_MOTD=Добро пожаловать. Введите help или projects.
SITE_URL=http://localhost

# Frontend (docker-compose)
NUXT_PUBLIC_API_BASE_URL=
NUXT_API_INTERNAL_URL=http://backend:8000
NUXT_PUBLIC_SITE_NAME=personal_me
NUXT_PUBLIC_BRAND_NAME=DAUTOVTECH
NUXT_PUBLIC_OWNER_NAME=Your Name
NUXT_PUBLIC_TAGLINE=Интерактивный командный центр: портфолио, интеграции и сервисы в одном терминале.
NUXT_PUBLIC_SITE_URL=http://localhost
NUXT_VITE_HMR_CLIENT_PORT=80
