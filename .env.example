# Backend
POSTGRES_DSN=postgresql+psycopg://app:app@db:5432/personal_me
JWT_SECRET_KEY=change-me-to-random-long-secret
ALLOW_REGISTRATION=false
EXPOSE_RESET_TOKEN=false
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
CORS_ORIGINS=http://localhost
AUTH_RATE_LIMIT_PER_MINUTE=30
OIDC_ISSUER=http://localhost/api/v1/oidc
OIDC_FRONTEND_BASE_URL=http://localhost
OIDC_AUTO_APPROVE=true

# Email (password reset). Leave SMTP_HOST empty to disable.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true

# Initial admin (only used on first seed)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me
INITIAL_ADMIN_EMAIL=

# Frontend (docker-compose)
NUXT_PUBLIC_API_BASE_URL=
NUXT_API_INTERNAL_URL=http://backend:8000
